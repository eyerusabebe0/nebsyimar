# Server Configuration
NODE_ENV=production
PORT=5000
API_VERSION=v1

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nefsyimar_db
DB_USER=postgres
DB_PASSWORD=9443

# Security
BCRYPT_SALT_ROUNDS=12
ENCRYPTION_KEY=your-32-character-encryption-key
SESSION_SECRET=nefsyimar-super-secret-session-key-2024
JWT_SECRET=nefsyimar-jwt-secret-key-2024-super-secure

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Payment Gateway URLs (Mock for development)
TELEBIRR_API_URL=https://api.telebirr.com
CBE_BIRR_API_URL=https://api.cbebirr.com
HELLO_CASH_API_URL=https://api.hellocash.com
PAYPAL_API_URL=https://api.paypal.com

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback
SUPER_ADMIN_EMAIL=founder@nefsyimar.com
SUPER_ADMIN_PASSWORD=password123